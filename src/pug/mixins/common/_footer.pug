mixin footer( page )

  footer.c-section.c-footer(class="pb-[1.25rem] tablet:pb-[0.938rem]")
    .c-section__inner.c-footer__inner
      .c-footer__logo
        img.c-footer__logoImage(class="w-[25.5rem]" src=`${dirPath}assets/images/common/logo_img_2.svg`, alt="Sauna Pro Team RUSH", width=`345`, height=`94`, decoding=`async`, loading=`lazy`)
      .c-footer__copyright
        small.c-footer__small Copyright &copy;2025 RUSH, inc. All Rights Reserved.
