//- ====================
//- 【概要】 top　store
//- 【詳細】
//- ====================
mixin store()
  include ./common/_title.pug
  include ./common/_button.pug

  section.c-section(class="pt-[10rem] tablet:pt-[7.5rem]")
    div(class="absolute top-[8.125rem] left-[50%] -translate-x-1/2 rotate-[-7deg] z-10 w-full tablet:top-[5.188rem]")
      ul.c-autoSlider
        li
          img.c-labelImage(src=`${dirPath}assets/images/common/label_brown.webp`, alt="Sauna Pro Team RUSH", width=`1363`, height=`30`, decoding=`async`, loading=`lazy`)
        li
          img.c-labelImage(src=`${dirPath}assets/images/common/label_brown.webp`, alt="Sauna Pro Team RUSH", width=`1363`, height=`30`, decoding=`async`, loading=`lazy`)
        li
          img.c-labelImage(src=`${dirPath}assets/images/common/label_brown.webp`, alt="Sauna Pro Team RUSH", width=`1363`, height=`30`, decoding=`async`, loading=`lazy`)
        li
          img.c-labelImage(src=`${dirPath}assets/images/common/label_brown.webp`, alt="Sauna Pro Team RUSH", width=`1363`, height=`30`, decoding=`async`, loading=`lazy`)
    div(class="absolute bottom-[-10rem] left-[50%] -translate-x-1/2 rotate-[5deg] z-20 w-full tablet:bottom-[-7.813rem]")
      ul.c-autoSlider._reverse_
        li
          img.c-labelImage(src=`${dirPath}assets/images/common/label_black.webp`, alt="Sauna Pro Team RUSH", width=`1363`, height=`30`, decoding=`async`, loading=`lazy`)
        li
          img.c-labelImage(src=`${dirPath}assets/images/common/label_black.webp`, alt="Sauna Pro Team RUSH", width=`1363`, height=`30`, decoding=`async`, loading=`lazy`)
        li
          img.c-labelImage(src=`${dirPath}assets/images/common/label_black.webp`, alt="Sauna Pro Team RUSH", width=`1363`, height=`30`, decoding=`async`, loading=`lazy`)
        li
          img.c-labelImage(src=`${dirPath}assets/images/common/label_black.webp`, alt="Sauna Pro Team RUSH", width=`1363`, height=`30`, decoding=`async`, loading=`lazy`)
    .c-section__inner._small_
      div(class="tablet:flex tablet:gap-[6.688rem]")
        ul.js-storeSlider.c-slider(class="tablet:w-[43.313rem] tablet:flex-shrink-0")
          - for (var val = 1; val <= 4; val++)
            li.js-storeSlider__item.c-slider__item
              img(class="" src=`${dirPath}assets/images/top/store_main_img_${val}.webp`, alt="", width=`1356`, height=`196`, decoding=`async`, loading=`lazy`)
        div(class="mt-[3.75rem] tablet:mt-0")
          +title({
            main: 'サウナ屋のお店',
            sub: 'rush web store',
            className: '_pcLeft_',
          })
          p.c-text.text-center(class="mt-[1.875rem] tablet:text-left") RUSHのオリジナルアパレルや小物。#[br]施工中の現場や打ち合わせでも#[br(class="tablet:hidden")]RUSHがRUSHらしくいられるように。#[br(class="tablet:hidden")]いつもわんぱくで楽しく、#[br(class="tablet:hidden")]サウナと真摯に向き合うためのアイテムたちです。#[br]RUSHとお揃いのアイテムをまとって、#[br]サウナライフをチューンしませんか？
          +button({
            Elm: 'a',
            text: 'サウナウェブストアを見る',
          })(class="w-full mx-auto mt-[2.5rem] hidden tablet:block" href="https://rush37.official.ec/" target="_blank" rel="noreferrer")
      div(class="max-w-[35rem] mt-[3.75rem] mx-auto tablet:max-w-none")
        ul.js-storeSliderSub.grid.grid-cols-2.c-sliderGrid(class="gap-[5rem] tablet:grid-cols-4 tablet:gap-[2.5rem]")
          li.js-storeSliderSub__item.c-sliderGrid__item
            img(class="" src=`${dirPath}assets/images/top/store_sub_img_1.webp`, alt="", width=`1356`, height=`196`, decoding=`async`, loading=``)
            img(class="" src=`${dirPath}assets/images/top/store_sub_img_5.webp`, alt="", width=`1356`, height=`196`, decoding=`async`, loading=``)
            img(class="" src=`${dirPath}assets/images/top/store_sub_img_9.webp`, alt="", width=`1356`, height=`196`, decoding=`async`, loading=``)
          li.js-storeSliderSub__item.c-sliderGrid__item
            img(class="" src=`${dirPath}assets/images/top/store_sub_img_2.webp`, alt="", width=`1356`, height=`196`, decoding=`async`, loading=``)
            img(class="" src=`${dirPath}assets/images/top/store_sub_img_6.webp`, alt="", width=`1356`, height=`196`, decoding=`async`, loading=``)
            img(class="" src=`${dirPath}assets/images/top/store_sub_img_10.webp`, alt="", width=`1356`, height=`196`, decoding=`async`, loading=``)
          li.js-storeSliderSub__item.c-sliderGrid__item
            img(class="" src=`${dirPath}assets/images/top/store_sub_img_3.webp`, alt="", width=`1356`, height=`196`, decoding=`async`, loading=``)
            img(class="" src=`${dirPath}assets/images/top/store_sub_img_7.webp`, alt="", width=`1356`, height=`196`, decoding=`async`, loading=``)
          li.js-storeSliderSub__item.c-sliderGrid__item
            img(class="" src=`${dirPath}assets/images/top/store_sub_img_4.webp`, alt="", width=`1356`, height=`196`, decoding=`async`, loading=``)
            img(class="" src=`${dirPath}assets/images/top/store_sub_img_8.webp`, alt="", width=`1356`, height=`196`, decoding=`async`, loading=``)
        +button({
          Elm: 'a',
          text: 'サウナウェブストアを見る',
        })(class="w-full mx-auto mt-[5rem] tablet:hidden" href="https://rush37.official.ec/" target="_blank" rel="noreferrer")