{
  "name": "template",
  "version": "2.0.0",
  "description": "static template",
  "private": true,
  "scripts": {
    "comment1": "---------------ローカルサーバー立ち上げ----------------",
    "dev": "node ./server.js",
    "comment2": "---------------ビルドコマンド----------------",
    "build": "rimraf ./dist && webpack --config webpack.prod.js && rimraf ./dist/assets/js/setting.js",
    "build:test": "rimraf ./dist_test && webpack --config webpack.dev.js && rimraf ./dist_test/assets/js/setting.js",
    "dev-server": "webpack-dev-server --config webpack.local.js",
    "comment3": "---------------画像変換----------------",
    "sharp": "npm run sharp-webp & npm run sharp-png & npm run sharp-jpg",
    "sharp-webp": "sharp -i ./img_converter/targets/*.jpg ./img_converter/targets/*.png -f webp -o ./img_converter/results",
    "sharp-jpg": "sharp -i ./img_converter/targets/*.jpg -o ./img_converter/results",
    "sharp-png": "sharp -i ./img_converter/targets/*.png -o ./img_converter/results"
  },
  "keywords": [],
  "author": "slowtime-design-inc",
  "license": "UNLICENSED",
  "devDependencies": {
    "@babel/cli": "^7.25.6",
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.4",
    "@fortawesome/fontawesome-free": "^6.6.0",
    "@fortawesome/fontawesome-svg-core": "^6.6.0",
    "@fortawesome/free-regular-svg-icons": "^6.6.0",
    "@fortawesome/free-solid-svg-icons": "^6.6.0",
    "autoprefixer": "^10.4.20",
    "babel-loader": "^9.1.3",
    "browser-sync": "^3.0.2",
    "copy-webpack-plugin": "^12.0.2",
    "css-hot-loader": "^1.4.4",
    "css-loader": "^7.1.2",
    "cssnano": "^7.0.6",
    "extract-loader": "^5.1.0",
    "file-loader": "^6.2.0",
    "globule": "^1.3.4",
    "html-loader": "^5.1.0",
    "html-webpack-plugin": "^5.6.0",
    "mini-css-extract-plugin": "^2.9.1",
    "normalize-url": "^8.0.1",
    "npm-check-updates": "^17.1.1",
    "postcss-custom-media": "^11.0.1",
    "postcss-loader": "^8.1.1",
    "postcss-sort-media-queries": "^5.2.0",
    "postcss-sorting": "^8.0.2",
    "pug-html-loader": "^1.1.5",
    "pug-lint": "^2.7.0",
    "pug-loader": "^2.4.0",
    "rimraf": "^6.0.1",
    "sass": "^1.78.0",
    "sass-loader": "^16.0.1",
    "sharp-cli": "^5.0.0",
    "style-loader": "^4.0.0",
    "tailwindcss": "^3.0.10",
    "url": "^0.11.4",
    "webpack": "^5.94.0",
    "webpack-bundle-analyzer": "^4.10.2",
    "webpack-cli": "^5.1.4",
    "webpack-dev-middleware": "^7.4.2",
    "webpack-dev-server": "^5.1.0",
    "webpack-glob-entries": "^1.0.1",
    "webpack-hot-middleware": "^2.26.1",
    "webpack-merge": "^6.0.1"
  },
  "dependencies": {
    "@splidejs/splide": "^4.1.4",
    "@splidejs/splide-extension-auto-scroll": "^0.5.3",
    "core-js": "^3.38.1",
    "gsap": "^3.12.7",
    "smooth-scroll": "^16.1.3"
  }
}
